# Copy to .env.local and set values. Required for production where noted.

# Required in production. Long random string for HMAC session tokens.
SESSION_SECRET=

# Public site (Ovesta)
NEXT_PUBLIC_SITE_NAME=Ovesta
NEXT_PUBLIC_SITE_DOMAIN=ovesta.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_CURRENCY=USD

# Required for the AI product assistant. Without it, POST /api/ai/chat returns 503.
OPENAI_API_KEY=
# Optional. Default is gpt-4o-mini in app/api/ai/chat/route.ts
OPENAI_MODEL=
