# Copy to .env.local and set values. Required in production where noted.

# Required in production. Long random string for HMAC session tokens.
SESSION_SECRET=

# Public site (Ovesta / ovestastore.com)
NEXT_PUBLIC_SITE_NAME=Ovesta Store
NEXT_PUBLIC_SITE_DOMAIN=ovestastore.com
# Use https://ovestastore.com in production. For local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://ovestastore.com
NEXT_PUBLIC_CURRENCY=USD

# Optional. Enables live chat store help. Without it, POST /api/chat returns 503.
OPENAI_API_KEY=
# Optional model override. Default: gpt-4o-mini in app/api/chat/route.ts
OPENAI_MODEL=
